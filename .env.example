# Analion API Keys
# Copy to .env and fill in your keys

# Mistral API (primary AI backend)
# Get key: https://console.mistral.ai/
MISTRAL_API_KEY=

# Second Mistral key (fallback)
MISTRAL_API_KEY_2=

# Default backend: template | mistral
ANALION_BACKEND=template

# Server
ANALION_PORT=8101
ANALION_HOST=0.0.0.0
